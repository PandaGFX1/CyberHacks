		{"id":"af291324c3987914","type":"text","text":"```dataview  \nTABLE without ID row.file.link AS Name, truncate(string(date(today) - Birthday),2, \"\") AS Age  \nFROM \"People\"  \nWHERE dateformat(Birthday,\"dd-MM\") = dateformat(date(now), \"dd-MM\")  \n```","x":-520,"y":-280,"width":420,"height":100,"color":"#bc6296"},
