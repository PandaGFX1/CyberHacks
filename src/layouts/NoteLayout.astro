---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
const { title, description, category, tags = [] } = Astro.props;
---
<BaseLayout title={`${title} — CyberHacks`} description={description}>
  <SiteHeader />
  <div class="note-shell">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-inner">
        <nav class="sidebar-nav">
          <slot name="sidebar" />
        </nav>
      </div>
    </aside>
    <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">‹</button>
	<div class="note-gap"></div>
    <main class="note-main">
      <div class="note-content">
        <div class="note-meta">
          {category && <span class="note-category">{category}</span>}
          {tags.map(t => <span class="note-tag">{t}</span>)}
        </div>
        <slot />
      </div>
    </main>
    <aside class="toc" id="toc">
      <div class="toc-inner">
        <p class="toc-label">On this page</p>
        <slot name="toc" />
      </div>
    </aside>
    <div class="note-spacer"></div>
  </div>
</BaseLayout>

<style>
/* ── SHELL GRID ── */
.note-shell {
  display: grid;
  grid-template-columns: 240px minmax(3rem, 1fr) auto 220px minmax(3rem, 1fr);
  grid-template-areas: "sidebar gap main toc spacer";
  min-height: calc(100vh - 56px);
}

/* ── SIDEBAR ── */
.sidebar {
  grid-area: sidebar;
  background: var(--surface);
  border-right: 1px solid var(--border);
  position: sticky;
  top: 56px;
  height: calc(100vh - 56px);
  overflow-y: auto;
  padding: 1.5rem 0;
  transition: width 0.25s ease, opacity 0.25s ease;
}

.sidebar-inner {
  position: relative;
  min-height: 100%;
}

.sidebar[data-collapsed] {
  width: 0;
  opacity: 0;
  overflow: hidden;
  padding: 0;
}

/* ── SIDEBAR TOGGLE ── */
.sidebar-toggle {
  position: fixed;
  top: 50vh;
  transform: translateY(-50%);
  z-index: 200;
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-left: none;
  color: var(--text-muted);
  width: 14px;
  height: 44px;
  border-radius: 0 6px 6px 0;
  cursor: pointer;
  font-size: 0.7rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s, color 0.15s, left 0.25s;
  left: 240px;
}

.sidebar-toggle:hover {
  background: var(--purple-3);
  color: white;
  border-color: var(--purple-3);
}

/* ── MAIN CONTENT ── */
.note-main {
  grid-area: main;
  min-width: 0;
  padding: 2rem 2.5rem 4rem 2rem;
}

.note-gap { 
  grid-area: gap;
}

.note-content {
  width: 800px;
  max-width: 100%;
  background: rgba(14, 10, 26, 0.55);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid rgba(61, 48, 96, 0.5);
  border-radius: 16px;
  padding: 2.5rem 3rem;
  box-shadow: 0 8px 48px rgba(0,0,0,0.4), inset 0 1px 0 rgba(124,92,232,0.08);
}

.note-meta {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 1.5rem;
}

.note-category {
  background: var(--purple-4);
  color: var(--purple-1);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.2rem 0.6rem;
  border-radius: 4px;
}

.note-tag {
  background: var(--surface-2);
  color: var(--text-muted);
  font-size: 0.7rem;
  padding: 0.2rem 0.5rem;
  border-radius: 4px;
  border: 1px solid var(--border);
}

/* ── TOC ── */
.toc {
  grid-area: toc;
  padding: 2rem 0 2rem 0;
  width: 220px;
}

.note-spacer {
  grid-area: spacer;
}

/* ── RESPONSIVE ── */
@media (max-width: 1200px) {
  .note-shell {
    grid-template-columns: 240px 1fr;
    grid-template-areas: "sidebar main";
  }
  .toc { display: none; }
  .note-spacer { display: none; }
}

@media (max-width: 768px) {
  .note-shell {
    grid-template-columns: 1fr;
    grid-template-areas: "main";
  }
  .sidebar { display: none; }
  .sidebar-toggle { display: none; }
  .note-main { padding: 1.5rem; }
}
</style>

<script>
const toggle = document.getElementById('sidebar-toggle');
const sidebar = document.getElementById('sidebar');
if (toggle && sidebar) {
  let collapsed = localStorage.getItem('sidebar') === '1';

  function apply(c) {
    if (c) {
      sidebar.setAttribute('data-collapsed', '');
      toggle.textContent = '›';
      toggle.style.left = '0px';
    } else {
      sidebar.removeAttribute('data-collapsed');
      toggle.textContent = '‹';
      toggle.style.left = '240px';
    }
  }

  apply(collapsed);

  toggle.addEventListener('click', () => {
    collapsed = !collapsed;
    localStorage.setItem('sidebar', collapsed ? '1' : '0');
    apply(collapsed);
  });
}
</script>
