---
const current = Astro.url.pathname;
const nav = [
  { label: 'Knowledge', href: '/knowledge' },
  { label: 'Techniques', href: '/techniques' },
  { label: 'Playbooks', href: '/playbooks' },
  { label: 'Tools', href: '/tools' },
  { label: 'Resources', href: '/resources' },
  { label: 'Labs', href: '/labs' },
];
---

<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo">
      <span class="logo-icon">⬡</span>
      <span class="logo-text">CyberHacks</span>
    </a>
    <nav class="header-nav">
      {nav.map(item => (
        <a href={item.href} class={`nav-link ${current.startsWith(item.href) ? 'active' : ''}`}>
          {item.label}
        </a>
      ))}
    </nav>
    <div class="hdr-search" id="hdr-search">
      <div class="hdr-search-box">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="color:var(--text-dim);flex-shrink:0"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input id="hdr-input" type="text" placeholder="Search notes..." autocomplete="off" spellcheck="false" />
        <kbd>⌘K</kbd>
      </div>
      <div class="hdr-dropdown" id="hdr-dropdown" style="display:none">
        <div id="hdr-results"></div>
        <a id="hdr-all" href="/search" class="hdr-view-all">View all results →</a>
      </div>
    </div>
  </div>
</header>

<style is:global>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  height: 56px;
  background: rgba(9,7,15,0.93);
  backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
}
.header-inner {
  display: flex;
  align-items: center;
  gap: 2rem;
  height: 100%;
  padding: 0 1.5rem;
}
.logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--text);
  font-family: var(--font-display);
  font-weight: 800;
  font-size: 1.1rem;
  text-decoration: none;
  flex-shrink: 0;
  letter-spacing: -0.02em;
}
.logo-icon { color: var(--purple-3); }
.logo:hover { color: var(--purple-1); }
.header-nav {
  display: flex;
  align-items: center;
  gap: 0.2rem;
}
.nav-link {
  color: var(--text-muted);
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 0.35rem 0.7rem;
  border-radius: 6px;
  text-decoration: none;
  transition: color 0.15s, background 0.15s;
  position: relative;
}
.nav-link:hover { color: var(--purple-1); background: var(--surface); }
.nav-link.active { color: var(--purple-2); background: var(--surface); }
.nav-link.active::after {
  content: '';
  position: absolute;
  bottom: -1px; left: 0.7rem; right: 0.7rem;
  height: 2px;
  background: var(--purple-3);
  border-radius: 2px 2px 0 0;
}

/* ── SEARCH ── */
.hdr-search {
  position: relative;
  flex-shrink: 0;
}
.hdr-search-box {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.28rem 0.6rem;
  width: 210px;
  transition: border-color 0.15s;
  cursor: text;
}
.hdr-search-box:focus-within {
  border-color: var(--purple-3);
}
#hdr-input {
  background: transparent;
  border: none;
  outline: none;
  color: var(--text);
  font-size: 0.8rem;
  font-family: var(--font-sans);
  width: 100%;
}
#hdr-input::placeholder { color: var(--text-dim); }
.hdr-search-box kbd {
  font-size: 0.58rem;
  background: var(--surface-2);
  border: 1px solid var(--border-2);
  border-radius: 4px;
  padding: 0.1rem 0.3rem;
  color: var(--text-dim);
  flex-shrink: 0;
}

/* Dropdown */
.hdr-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  right: 0;
  width: 380px;
  background: rgba(11,8,20,0.98);
  border: 1px solid var(--border-2);
  border-radius: 10px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.7);
  padding: 0.35rem;
  z-index: 999;
}
#hdr-results {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  max-height: 420px;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: var(--border-2) transparent;
}

#hdr-results::-webkit-scrollbar {
  width: 3px;
}

#hdr-results::-webkit-scrollbar-track {
  background: transparent;
}

#hdr-results::-webkit-scrollbar-thumb {
  background: var(--border-2);
  border-radius: 3px;
}

#hdr-results::-webkit-scrollbar-thumb:hover {
  background: var(--purple-3);
}
.hdr-result {
  display: block;
  padding: 0.6rem 0.75rem;
  background: rgba(20,15,34,0.8);
  border: 1px solid rgba(42,32,64,0.9);
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.15s, border-color 0.15s, transform 0.15s;
  cursor: pointer;
  overflow: hidden;
}
.hdr-result:hover {
  background: rgba(90,61,184,0.2);
  border-color: var(--purple-3);
  transform: translateX(2px);
  pointer-events: auto;
}
.hdr-result-title {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  line-height: 1.3;
  margin-bottom: 0.2rem;
}
.hdr-result:hover .hdr-result-title { color: var(--purple-1); }
.hdr-result-path {
  font-size: 0.62rem;
  color: var(--text-dim);
  text-transform: capitalize;
  letter-spacing: 0.02em;
}
.hdr-result-path span {
  color: var(--purple-3);
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-size: 0.58rem;
}
.hdr-empty {
  padding: 1rem;
  text-align: center;
  color: var(--text-dim);
  font-size: 0.76rem;
}
.hdr-view-all {
  display: block;
  margin-top: 0.3rem;
  padding: 0.45rem 0.75rem;
  background: rgba(20,15,34,0.5);
  border: 1px solid var(--border);
  border-radius: 7px;
  font-size: 0.7rem;
  color: var(--text-muted);
  text-align: center;
  text-decoration: none;
  transition: color 0.15s, border-color 0.15s;
  flex-shrink: 0;
}
.hdr-view-all:hover {
  color: var(--purple-2);
  border-color: var(--purple-3);
  background: rgba(20,15,34,0.5);
  transform: none;
}

.hdr-result-excerpt {
  font-size: 0.62rem;
  color: var(--text-muted);
  line-height: 1.35;
  margin-top: 0.25rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 100%;
}

.hdr-result-excerpt mark {
  background: rgba(124, 92, 232, 0.3);
  color: var(--purple-1);
  border-radius: 2px;
  padding: 0 2px;
  font-style: normal;
}

@media (max-width: 768px) {
  .header-nav { display: none; }
  .hdr-search-box kbd { display: none; }
  .hdr-dropdown { width: calc(100vw - 2rem); right: -0.5rem; }
}
</style>

<script is:inline>
(function(){
  let pf = null;
  let timer = null;
  const input = document.getElementById('hdr-input');
  const dropdown = document.getElementById('hdr-dropdown');
  const results = document.getElementById('hdr-results');
  const viewAll = document.getElementById('hdr-all');
  if(!input) return;

  async function init() {
    if(pf) return pf;
    try {
      pf = await import('/pagefind/pagefind.js');
      await pf.init();
    } catch(e){ pf=null; }
    return pf;
  }

  input.addEventListener('focus', init);

  input.addEventListener('input', ()=>{
    clearTimeout(timer);
    timer = setTimeout(async ()=>{
      const q = input.value.trim();
      if(!q){ dropdown.style.display='none'; return; }

      const lib = await init();
      if(!lib){
        results.innerHTML = '<div class="hdr-empty">Run a build to enable search.</div>';
        dropdown.style.display='block';
        return;
      }

      const res = await lib.search(q);
      const top = await Promise.all(res.results.slice(0,5).map(r=>r.data()));
      viewAll.href = '/search?q='+encodeURIComponent(q);

      if(!top.length){
        results.innerHTML = '<div class="hdr-empty">No results for "'+q+'"</div>';
      } else {
        results.innerHTML = top.map(r=>{
          const parts = r.url.split('/').filter(Boolean);
          const cat = parts[0]||'';
          const sub = parts.length>2 ? parts[1].replace(/-/g,' ') : '';
          const title = (r.meta&&r.meta.title||'')
            .replace(/\s*[—–-]+\s*CyberHacks\s*$/i,'').trim()
            || parts[parts.length-1].replace(/-/g,' ');
          const path = sub ? `<span>${cat}</span> / ${sub}` : `<span>${cat}</span>`;
          const excerpt = (r.excerpt||'')
            .replace(/<(?!\/?mark)[^>]+>/g,'')
            .replace(/\s+/g,' ')
            .replace(/^[\s\/\-–—]+/,'')
            .trim()
            .slice(0,90);
          return '<a href="'+r.url+'" class="hdr-result">'
            +'<div class="hdr-result-title">'+title+'</div>'
            +'<div class="hdr-result-path">'+path+'</div>'
            +(excerpt?'<div class="hdr-result-excerpt">'+excerpt+'</div>':'')
            +'</a>';
        }).join('');
      }
      dropdown.style.display='block';
    }, 180);
  });

  document.addEventListener('click', e=>{
    if(!document.getElementById('hdr-search').contains(e.target))
      dropdown.style.display='none';
  });

  document.addEventListener('keydown', e=>{
    if((e.metaKey||e.ctrlKey)&&e.key==='k'){
      e.preventDefault(); input.focus(); input.select();
    }
    if(e.key==='Escape'){ dropdown.style.display='none'; input.blur(); }
    if(e.key==='Enter'&&dropdown.style.display!=='none'&&input.value.trim())
      window.location.href='/search?q='+encodeURIComponent(input.value.trim());
  });
})();
</script>
