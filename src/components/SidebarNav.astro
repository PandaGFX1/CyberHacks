---
import { getCollection } from 'astro:content';

const { currentSlug = '' } = Astro.props;
const currentCategory = currentSlug.split('/')[0];

const allNotes = await getCollection('notes');

const tree = {};

for (const note of allNotes) {
  const parts = note.id.split('/');
  const category = parts[0];
  const subcategory = parts.length > 2 ? parts.slice(1, -1).join('/') : '_root';
  const title = note.data.title || parts[parts.length - 1].replace(/-/g, ' ');

  if (!tree[category]) tree[category] = {};
  if (!tree[category][subcategory]) tree[category][subcategory] = [];
  tree[category][subcategory].push({ slug: note.id, title });
}

const CATEGORY_ORDER = ['knowledge', 'techniques', 'playbooks', 'tools', 'labs', 'resources'];
const sortedCategories = Object.keys(tree).sort((a, b) => {
  const ai = CATEGORY_ORDER.indexOf(a);
  const bi = CATEGORY_ORDER.indexOf(b);
  if (ai === -1 && bi === -1) return a.localeCompare(b);
  if (ai === -1) return 1;
  if (bi === -1) return -1;
  return ai - bi;
});

const CATEGORY_LABELS = {
  knowledge: 'Knowledge',
  techniques: 'Techniques',
  playbooks: 'Playbooks',
  tools: 'Tools',
  labs: 'Labs',
  resources: 'Resources',
};
---

<nav class="sidebar-tree">
  {sortedCategories.map(category => {
    const isCurrentCat = category === currentCategory;
    const subcats = tree[category];
    const sortedSubcats = Object.keys(subcats).sort((a, b) =>
      a === '_root' ? -1 : b === '_root' ? 1 : a.localeCompare(b)
    );
    const totalNotes = Object.values(subcats).flat().length;

    return (
      <div class="cat-group" data-open={isCurrentCat ? 'true' : 'false'}>
        <div class="cat-header">
          <button class="cat-toggle" aria-label="Toggle category">
            <span class="cat-chevron">▶</span>
          </button>
          <a href={`/${category}`} class={`cat-label-link ${isCurrentCat ? 'active' : ''}`}>
            {CATEGORY_LABELS[category] || category}
          </a>
          <span class="cat-count">{totalNotes}</span>
        </div>

        <div class="cat-body">
          {sortedSubcats.map(subcat => {
            const notes = subcats[subcat].sort((a, b) => a.title.localeCompare(b.title));

            if (subcat === '_root') {
              return notes.map(note => (
                <a
                  href={`/${note.slug}`}
                  class={`nav-note ${currentSlug === note.slug ? 'active' : ''}`}
                >
                  {note.title}
                </a>
              ));
            }

            const subcatLabel = subcat
              .split('/')
              .pop()
              .replace(/-/g, ' ')
              .replace(/\b\w/g, c => c.toUpperCase());

            const isCurrentSubcat = notes.some(n => n.slug === currentSlug);
            const filterLabel = subcatLabel;

            return (
              <div class="subcat-group" data-open={isCurrentSubcat ? 'true' : 'false'}>
                <div class="subcat-header">
                  <button class="subcat-toggle" aria-label="Toggle subcategory">
                    <span class="subcat-chevron">▶</span>
                  </button>
                  <a
                    href={`/${category}?filter=${encodeURIComponent(filterLabel)}`}
                    class={`subcat-label-link ${isCurrentSubcat ? 'active' : ''}`}
                  >
                    {subcatLabel}
                  </a>
                </div>
                <div class="subcat-body">
                  {notes.map(note => (
                    <a
                      href={`/${note.slug}`}
                      class={`nav-note ${currentSlug === note.slug ? 'active' : ''}`}
                    >
                      {note.title}
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    );
  })}
</nav>

<style>
.sidebar-tree {
  padding: 1rem 0;
  font-size: 0.82rem;
}

/* Category */
.cat-group { margin-bottom: 0.15rem; }

.cat-header {
  display: flex;
  align-items: center;
  gap: 0;
  margin: 0 0.5rem;
  border-radius: 4px;
  transition: background 0.15s;
}

.cat-header:hover {
  background: var(--surface-2);
}

.cat-header:hover .cat-toggle,
.cat-header:hover .cat-label-link {
  background: transparent;
}

.cat-toggle {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.4rem 0.5rem;
  color: var(--text-dim);
  border-radius: 4px 0 0 4px;
  transition: color 0.15s, background 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 1.8rem;
  flex-shrink: 0;
}

.cat-toggle:hover { color: var(--purple-2); }

.cat-chevron {
  font-size: 0.6rem;
  transition: transform 0.2s;
  display: inline-block;
}

.cat-label-link {
  flex: 1;
  padding: 0.4rem 0.25rem;
  font-size: 0.68rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-dim);
  text-decoration: none;
  transition: color 0.15s;
  border-radius: 0;
}

.cat-label-link:hover { color: var(--purple-2); }
.cat-label-link.active { color: var(--purple-2); }

.cat-count {
  font-size: 0.62rem;
  font-weight: 400;
  color: var(--text-dim);
  background: var(--surface-2);
  padding: 0.1rem 0.4rem;
  border-radius: 99px;
  min-width: 1.4rem;
  text-align: center;
  margin-right: 0.25rem;
  flex-shrink: 0;
}

.cat-body {
  display: none;
  padding: 0.1rem 0;
}

.cat-group[data-open="true"] .cat-body { display: block; }
.cat-group[data-open="true"] .cat-chevron { transform: rotate(90deg); }
.cat-group[data-open="true"] .cat-toggle { color: var(--purple-2); }

/* Subcategory */
.subcat-group { margin: 0.05rem 0; }

.subcat-header {
  display: flex;
  align-items: center;
  margin: 0 0.5rem 0 1rem;
  border-radius: 4px;
  transition: background 0.15s;
}

.subcat-header:hover {
  background: var(--surface-2);
}

.subcat-header:hover .subcat-toggle,
.subcat-header:hover .subcat-label-link {
  background: transparent;
}

.subcat-toggle {
  background: none;
  border: none;
  cursor: pointer;
  padding: 0.3rem 0.5rem;
  color: var(--text-dim);
  border-radius: 4px 0 0 4px;
  transition: color 0.15s, background 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 1.8rem;
  flex-shrink: 0;
}

.subcat-toggle:hover { color: var(--purple-1); }

.subcat-chevron {
  font-size: 0.55rem;
  transition: transform 0.2s;
  display: inline-block;
}

.subcat-label-link {
  flex: 1;
  padding: 0.3rem 0.25rem;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.15s;
}

.subcat-label-link:hover { color: var(--purple-1); }
.subcat-label-link.active { color: var(--purple-1); }

.subcat-body {
  display: none;
  padding: 0.1rem 0;
}

.subcat-group[data-open="true"] .subcat-body { display: block; }
.subcat-group[data-open="true"] .subcat-chevron { transform: rotate(90deg); }
.subcat-group[data-open="true"] .subcat-toggle { color: var(--purple-1); }

/* Notes */
.nav-note {
  display: block;
  padding: 0.28rem 1rem 0.28rem 3.5rem;
  font-size: 0.78rem;
  color: var(--text-muted);
  text-decoration: none;
  border-radius: 4px;
  margin: 0.05rem 0.5rem;
  transition: color 0.15s, background 0.15s;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.nav-note:hover { color: var(--purple-1); background: var(--surface-2); }

.nav-note.active {
  color: var(--purple-2);
  background: rgba(90, 61, 184, 0.15);
  border-left: 2px solid var(--purple-3);
  padding-left: calc(3.5rem - 2px);
  font-weight: 500;
}

.cat-body > .nav-note { padding-left: 2.5rem; }
.cat-body > .nav-note.active { padding-left: calc(2.5rem - 2px); }
</style>

<script>
document.querySelectorAll('.cat-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const group = btn.closest('.cat-group');
    group.dataset.open = group.dataset.open === 'true' ? 'false' : 'true';
  });
});

document.querySelectorAll('.subcat-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const group = btn.closest('.subcat-group');
    group.dataset.open = group.dataset.open === 'true' ? 'false' : 'true';
  });
});
</script>
