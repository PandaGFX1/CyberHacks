---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');
const total = allNotes.length;
const knowledge = allNotes.filter(n => (n.slug ?? n.id ?? '').startsWith('knowledge/')).length;
const techniques = allNotes.filter(n => (n.slug ?? n.id ?? '').startsWith('techniques/')).length;
const tools = allNotes.filter(n => (n.slug ?? n.id ?? '').startsWith('tools/')).length;
const playbooks = allNotes.filter(n => (n.slug ?? n.id ?? '').startsWith('playbooks/')).length;
const labs = allNotes.filter(n => (n.slug ?? n.id ?? '').startsWith('labs/')).length;
const resources = allNotes.filter(n => (n.slug ?? n.id ?? '').startsWith('resources/')).length;

const recentNotes = [...allNotes]
  .sort((a, b) => {
    const aDate = a.data.date ?? '';
    const bDate = b.data.date ?? '';
    return bDate.localeCompare(aDate);
  })
  .slice(0, 6)
  .map(n => ({
    slug: n.slug ?? n.id ?? '',
    title: n.data.title || (n.slug ?? n.id ?? '').split('/').pop().replace(/-/g, ' '),
    category: n.data.category || (n.slug ?? n.id ?? '').split('/')[0],
    excerpt: n.data.excerpt || '',
    date: n.data.date || '',
  }));
---

<BaseLayout title="CyberHacks — Cybersecurity Notes & Reference">
  <SiteHeader />

  <main class="home">
    <section class="hero">
      <div class="hero-eyebrow">
        <span class="dot"></span>
        Personal knowledge vault
      </div>
      <h1 class="hero-title">
        Hack the <span class="accent">knowledge</span><br />before the box
      </h1>
      <p class="hero-sub">
        Notes, playbooks, and tool references built from real HTB, THM, and CTF work.
        Not a tutorial site — a working reference.
      </p>

      <div class="stats-bar">
        <div class="stat">
          <span class="stat-number">{total}</span>
          <span class="stat-label">Total Notes</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">{knowledge}</span>
          <span class="stat-label">Knowledge</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">{tools}</span>
          <span class="stat-label">Tools</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">{techniques}</span>
          <span class="stat-label">Techniques</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">{playbooks}</span>
          <span class="stat-label">Playbooks</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-number">{labs}</span>
          <span class="stat-label">Labs</span>
        </div>
      </div>
    </section>

    <section class="categories">
      <a href="/knowledge" class="cat-card">
        <div class="cat-icon">◈</div>
        <div class="cat-body">
          <h2>Knowledge</h2>
          <p>Concepts, protocols, frameworks — the theory that makes techniques make sense.</p>
        </div>
        <span class="cat-count">{knowledge}</span>
      </a>
      <a href="/techniques" class="cat-card">
        <div class="cat-icon">◉</div>
        <div class="cat-body">
          <h2>Techniques</h2>
          <p>Step-by-step attack and defense methodology. Enumeration through exploitation.</p>
        </div>
        <span class="cat-count">{techniques}</span>
      </a>
      <a href="/playbooks" class="cat-card">
        <div class="cat-icon">◧</div>
        <div class="cat-body">
          <h2>Playbooks</h2>
          <p>Operational checklists for Linux pentesting, Windows, OSINT, and forensics.</p>
        </div>
        <span class="cat-count">{playbooks}</span>
      </a>
      <a href="/tools" class="cat-card">
        <div class="cat-icon">◈</div>
        <div class="cat-body">
          <h2>Tools</h2>
          <p>Full command reference for Nmap, Burp Suite, Metasploit, and every tool in the kit.</p>
        </div>
        <span class="cat-count">{tools}</span>
      </a>
      <a href="/labs" class="cat-card cat-card--labs">
        <div class="cat-icon">◎</div>
        <div class="cat-body">
          <h2>Labs</h2>
          <p>HTB, THM, and CTF writeups. Machine notes, exam reports, and SIEM triage.</p>
        </div>
        <span class="cat-count">{labs}</span>
      </a>
      <a href="/resources" class="cat-card">
        <div class="cat-icon">◆</div>
        <div class="cat-body">
          <h2>Resources</h2>
          <p>References, cheatsheets, and curated links for research and practice.</p>
        </div>
        <span class="cat-count">{resources}</span>
      </a>
    </section>

    <section class="recent-section">
      <div class="recent-header">
        <h2 class="recent-title">Recently Added</h2>
        <a href="/knowledge" class="recent-view-all">View all →</a>
      </div>
      <div class="recent-grid">
        {recentNotes.map(note => (
          <a href={`/${note.slug}`} class="recent-card">
            <div class="recent-card-top">
              <span class="recent-cat">{note.category}</span>
              {note.date && <span class="recent-date">{note.date}</span>}
            </div>
            <span class="recent-note-title">{note.title}</span>
            {note.excerpt && <span class="recent-excerpt">{note.excerpt}</span>}
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
.home {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 2rem;
  position: relative;
  z-index: 1;
}

/* ── HERO ── */
.hero {
  padding: 5rem 0 3rem;
  max-width: 720px;
}

.hero-eyebrow {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 1.5rem;
}

.dot {
  width: 6px;
  height: 6px;
  background: var(--purple-3);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.4; transform: scale(0.7); }
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: var(--text);
  margin-bottom: 1.5rem;
}

.accent { color: var(--purple-2); }

.hero-sub {
  font-size: 1.05rem;
  color: var(--text-muted);
  line-height: 1.7;
  max-width: 520px;
  margin-bottom: 2.5rem;
}

/* ── STATS BAR ── */
.stats-bar {
  display: flex;
  align-items: center;
  gap: 0;
  background: rgba(14, 10, 26, 0.55);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1rem 1.5rem;
  width: fit-content;
}

.stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 1.25rem;
  gap: 0.2rem;
}

.stat-number {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--purple-1);
  line-height: 1;
  letter-spacing: -0.02em;
}

.stat-label {
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.stat-divider {
  width: 1px;
  height: 2rem;
  background: var(--border);
  flex-shrink: 0;
}

/* ── CATEGORY CARDS ── */
.categories {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  padding-bottom: 4rem;
}

.cat-card {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.5rem;
  background: rgba(20, 15, 34, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  color: var(--text);
  transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  text-decoration: none;
  position: relative;
}

.cat-card:hover {
  border-color: var(--purple-3);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px var(--glow);
  color: var(--text);
}

.cat-icon {
  font-size: 1.3rem;
  color: var(--purple-3);
  flex-shrink: 0;
  line-height: 1;
  margin-top: 0.1rem;
}

.cat-body { flex: 1; min-width: 0; }
.cat-body h2 {
  font-size: 0.95rem;
  font-weight: 700;
  margin-bottom: 0.4rem;
  color: var(--purple-1);
}
.cat-body p {
  font-size: 0.82rem;
  color: var(--text-muted);
  line-height: 1.5;
}

.cat-count {
  position: absolute;
  top: 0.75rem;
  right: 0.75rem;
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--text-dim);
  background: var(--surface-2);
  border: 1px solid var(--border);
  padding: 0.15rem 0.45rem;
  border-radius: 99px;
}

.cat-card--labs::before {
  content: 'PRIVATE';
  position: absolute;
  bottom: 0.6rem;
  right: 0.75rem;
  font-size: 0.5rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  color: var(--purple-3);
  opacity: 0.6;
}

.cat-card--labs .cat-count {
  right: 4rem;
}

/* ── RECENTLY ADDED ── */
.recent-section {
  padding-bottom: 4rem;
}

.recent-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 1rem;
}

.recent-title {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
}

.recent-view-all {
  font-size: 0.72rem;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.15s;
}

.recent-view-all:hover { color: var(--purple-2); }

.recent-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.5rem;
}

.recent-card {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  padding: 0.85rem 1rem;
  background: rgba(20, 15, 34, 0.5);
  backdrop-filter: blur(8px);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-decoration: none;
  transition: border-color 0.15s, background 0.15s;
  min-height: 90px;
}

.recent-card:hover {
  border-color: var(--purple-3);
  background: rgba(90, 61, 184, 0.1);
}

.recent-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.5rem;
}

.recent-cat {
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--purple-3);
}

.recent-date {
  font-size: 0.6rem;
  color: var(--text-dim);
  letter-spacing: 0.03em;
}

.recent-note-title {
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text);
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recent-card:hover .recent-note-title { color: var(--purple-1); }

.recent-excerpt {
  font-size: 0.72rem;
  color: var(--text-muted);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style>
