---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const allNotes = await getCollection('notes');
const notes = allNotes
  .filter(n => n.id.startsWith('labs/'))
  .map(n => ({
    id: n.id,
    title: n.data.title || n.id.split('/').pop().replace(/-/g, ' '),
    subcategory: n.id.split('/').slice(1, 3).join(' / ') || 'Labs',
    tags: n.data.tags || [],
  }))
  .sort((a, b) => a.title.localeCompare(b.title));

const groups = notes.reduce((acc, note) => {
  const key = note.subcategory
    .replace(/-/g, ' ')
    .replace(/\b\w/g, c => c.toUpperCase());
  if (!acc[key]) acc[key] = [];
  acc[key].push(note);
  return acc;
}, {});

const sortedGroups = Object.entries(groups).sort(([a], [b]) => a.localeCompare(b));
const allSubcats = sortedGroups.map(([name]) => name);
---

<BaseLayout title="Labs — CyberHacks">
  <SiteHeader />
  <main class="index-page">
    <div class="index-header">
      <div class="index-eyebrow">
        <span class="dot"></span>
        {notes.length} writeups · private
      </div>
      <h1>Labs</h1>
      <p class="index-sub">HTB, THM, and CTF writeups. Machine notes and exam reports.</p>
    </div>

    <div class="filter-bar">
      <button class="filter-btn active" data-filter="all">All</button>
      {allSubcats.map(cat => (
        <button class="filter-btn" data-filter={cat}>{cat}</button>
      ))}
    </div>

    <div class="note-groups" id="note-groups">
      {sortedGroups.map(([groupName, groupNotes]) => (
        <div class="note-group" data-group={groupName}>
          <h2 class="group-title">{groupName}</h2>
          <div class="note-grid">
            {groupNotes.map(note => (
              <a href={`/${note.id}`} class="note-card">
                <span class="note-title">{note.title}</span>
                <span class="note-arrow">→</span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>

<style>
.index-page {
  position: relative;
  z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
  padding: 3rem 2rem 4rem;
}
.index-header { margin-bottom: 2.5rem; }
.index-eyebrow {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}
.dot { width: 6px; height: 6px; background: var(--purple-3); border-radius: 50%; }
h1 {
  font-family: var(--font-display);
  font-size: 2.5rem;
  font-weight: 800;
  color: var(--purple-1);
  letter-spacing: -0.02em;
  margin-bottom: 0.5rem;
}
.index-sub { color: var(--text-muted); font-size: 1rem; }
.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border);
}
.filter-btn {
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 0.75rem;
  font-family: var(--font-sans);
  font-weight: 500;
  padding: 0.3rem 0.75rem;
  border-radius: 99px;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.filter-btn:hover { border-color: var(--purple-3); color: var(--purple-2); }
.filter-btn.active { background: var(--purple-4); border-color: var(--purple-3); color: var(--purple-1); }
.note-group { margin-bottom: 2.5rem; }
.group-title {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-dim);
  margin-bottom: 0.75rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border);
}
.note-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 0.5rem;
}
.note-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.65rem 1rem;
  background: rgba(20, 15, 34, 0.5);
  backdrop-filter: blur(8px);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  text-decoration: none;
  transition: all 0.15s;
  gap: 0.5rem;
}
.note-card:hover { border-color: var(--purple-3); background: rgba(90, 61, 184, 0.12); transform: translateX(2px); }
.note-title { font-size: 0.85rem; color: var(--text); line-height: 1.3; }
.note-card:hover .note-title { color: var(--purple-1); }
.note-arrow { color: var(--text-dim); font-size: 0.8rem; flex-shrink: 0; transition: color 0.15s, transform 0.15s; }
.note-card:hover .note-arrow { color: var(--purple-2); transform: translateX(2px); }
.note-group[data-hidden] { display: none; }
</style>

<script>
const btns = document.querySelectorAll('.filter-btn');
const groups = document.querySelectorAll('.note-group');
function applyFilter(filter) {
  btns.forEach(b => {
    b.classList.toggle('active', b.dataset.filter === filter ||
      (filter === 'all' && b.dataset.filter === 'all'));
  });
  groups.forEach(group => {
    if (filter === 'all' || group.dataset.group === filter) {
      group.removeAttribute('data-hidden');
    } else {
      group.setAttribute('data-hidden', '');
    }
  });
}

// Check URL param on load
const params = new URLSearchParams(window.location.search);
const filterParam = params.get('filter');
if (filterParam) {
  applyFilter(filterParam);
} else {
  applyFilter('all');
}

btns.forEach(btn => {
  btn.addEventListener('click', () => {
    const filter = btn.dataset.filter;
    applyFilter(filter);
    // Update URL without reload
    const url = new URL(window.location);
    if (filter === 'all') {
      url.searchParams.delete('filter');
    } else {
      url.searchParams.set('filter', filter);
    }
    window.history.replaceState({}, '', url);
  });
});
</script>
