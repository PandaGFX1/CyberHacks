---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
---
<BaseLayout title="Search — CyberHacks">
  <SiteHeader />
  <main class="search-page">
    <div class="search-header">
      <h1>Search</h1>
      <p>Search across all notes, tools, playbooks, and techniques.</p>
    </div>
    <div id="search" class="search-widget"></div>
  </main>
</BaseLayout>

<style is:global>
.search-page {
  position: relative;
  z-index: 1;
  max-width: 860px;
  margin: 0 auto;
  padding: 3rem 2rem 4rem;
}

.search-header {
  margin-bottom: 2rem;
}

.search-header h1 {
  font-family: var(--font-display);
  font-size: 2.5rem;
  font-weight: 800;
  color: var(--purple-1);
  letter-spacing: -0.02em;
  margin-bottom: 0.5rem;
}

.search-header p {
  color: var(--text-muted);
  font-size: 1rem;
}

.search-widget {
  --pagefind-ui-scale: 0.9;
  --pagefind-ui-primary: #7c5ce8;
  --pagefind-ui-text: #e8e0ff;
  --pagefind-ui-background: rgba(14, 10, 26, 0.55);
  --pagefind-ui-border: #2a2040;
  --pagefind-ui-tag: #1c1630;
  --pagefind-ui-border-width: 1px;
  --pagefind-ui-border-radius: 8px;
  --pagefind-ui-font: 'Inter', sans-serif;
}

/* Input */
.pagefind-ui__search-input {
  background: rgba(14, 10, 26, 0.7) !important;
  border: 1px solid var(--border) !important;
  color: var(--text) !important;
  backdrop-filter: blur(12px) !important;
}

.pagefind-ui__search-input:focus {
  border-color: var(--purple-3) !important;
  outline: none !important;
  box-shadow: 0 0 0 3px rgba(124, 92, 232, 0.15) !important;
}

/* Result card */
.pagefind-ui__result {
  background: rgba(14, 10, 26, 0.55) !important;
  backdrop-filter: blur(20px) !important;
  border: 1px solid rgba(61, 48, 96, 0.5) !important;
  border-radius: 12px !important;
  padding: 1.25rem 1.5rem !important;
  margin-bottom: 0.75rem !important;
  cursor: pointer !important;
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s !important;
}

.pagefind-ui__result:hover {
  border-color: var(--purple-3) !important;
  box-shadow: 0 4px 24px rgba(124, 92, 232, 0.15) !important;
  transform: translateY(-1px) !important;
}

/* Main title — border-bottom separator */
.pagefind-ui__result-title {
  color: var(--purple-1) !important;
  font-weight: 700 !important;
  font-size: 1rem !important;
  padding-bottom: 0.6rem !important;
  margin-bottom: 0.6rem !important;
  border-bottom: 1px solid var(--border) !important;
  display: block !important;
}

.pagefind-ui__result-title a {
  color: inherit !important;
  text-decoration: none !important;
  border: none !important;
}

/* Sub-results — remove ALL borders, use left bar only */
.pagefind-ui__result-nested {
  border: none !important;
  border-left: 2px solid var(--border-2) !important;
  border-bottom: none !important;
  border-top: none !important;
  border-right: none !important;
  margin: 0.2rem 0 0.2rem 0.25rem !important;
  padding: 0.15rem 0 0.15rem 0.6rem !important;
  transition: border-left-color 0.15s !important;
}

.pagefind-ui__result-nested:hover {
  border-left-color: var(--purple-3) !important;
}

.pagefind-ui__result-nested-title {
  color: var(--purple-2) !important;
  font-size: 0.75rem !important;
  font-weight: 600 !important;
  margin-bottom: 0 !important;
  border: none !important;
  padding: 0 !important;
}

.pagefind-ui__result-nested-title a {
  color: inherit !important;
  text-decoration: none !important;
  border: none !important;
}

.pagefind-ui__result-excerpt {
  color: var(--text-muted) !important;
  font-size: 0.72rem !important;
  line-height: 1.4 !important;
  margin: 0 !important;
  padding-top: 0 !important;
}

/* Match highlights */
mark {
  background: rgba(124, 92, 232, 0.3) !important;
  color: var(--purple-1) !important;
  border-radius: 3px !important;
  padding: 0 2px !important;
}

/* Result count */
.pagefind-ui__message {
  color: var(--text-muted) !important;
  font-size: 0.8rem !important;
  margin-bottom: 1rem !important;
}

/* Clear button */
.pagefind-ui__search-clear {
  color: var(--text-muted) !important;
  background: transparent !important;
}

/* Load more */
.pagefind-ui__button {
  background: var(--surface) !important;
  border: 1px solid var(--border) !important;
  color: var(--text-muted) !important;
  border-radius: 8px !important;
  transition: border-color 0.15s, color 0.15s !important;
}

.pagefind-ui__button:hover {
  border-color: var(--purple-3) !important;
  color: var(--purple-1) !important;
}

/* Hide arrow icons on nested results */
.pagefind-ui__result-nested-title::before {
  display: none !important;
  content: none !important;
}

.pagefind-ui__result-link-arrow {
  display: none !important;
}

/* Hide ↵ character pagefind adds */
.pagefind-ui__result-title::after,
.pagefind-ui__result-nested-title::after {
  display: none !important;
  content: none !important;
}

/* Sub-result label prefix arrow */
.pagefind-ui__result-nested .pagefind-ui__result-link::before {
  display: none !important;
  content: '' !important;
}

/* Nuclear reset — override pagefind's own stylesheet */
.pagefind-ui__result-nested,
.pagefind-ui__result-nested *,
.pagefind-ui__result-excerpt {
  border-top: none !important;
  border-right: none !important;
  border-bottom: none !important;
  box-shadow: none !important;
}

.pagefind-ui__result-nested {
  border-left: 2px solid var(--border-2) !important;
}

.pagefind-ui__result-nested:hover {
  border-left-color: var(--purple-3) !important;
}

.pagefind-ui__result-nested p,
.pagefind-ui__result-nested div,
.pagefind-ui__result-nested span {
  margin: 0 !important;
  padding: 0 !important;
}
</style>

<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    const script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.onload = () => {
      new PagefindUI({
        element: '#search',
        showSubResults: true,
        excerptLength: 15,
        showImages: false,
      });

      // Make entire result block and sub-results clickable
      document.getElementById('search').addEventListener('click', (e) => {
        if (e.target.closest('a')) return; // already a link click

        // Check if clicked inside a sub-result
        const nested = e.target.closest('.pagefind-ui__result-nested');
        if (nested) {
          const link = nested.querySelector('a');
          if (link) { link.click(); return; }
        }

        // Otherwise click the main result title
        const result = e.target.closest('.pagefind-ui__result');
        if (!result) return;
        const link = result.querySelector('.pagefind-ui__result-title a');
        if (link) link.click();
      });

      // Watch for new results (pagefind renders dynamically)
      const observer = new MutationObserver(() => {
        document.querySelectorAll('.pagefind-ui__result').forEach(result => {
          result.style.cursor = 'pointer';
        });
      });
      observer.observe(document.getElementById('search'), { childList: true, subtree: true });
    };
    script.onerror = () => {
      document.getElementById('search').innerHTML =
        '<p style="color:#8070a8;padding:1rem">Search index not built yet. Run <code>npx astro build</code> first.</p>';
    };
    document.head.appendChild(script);

    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = '/pagefind/pagefind-ui.css';
    document.head.appendChild(link);

    // Handle ?q= param to pre-fill search from other pages
    const params = new URLSearchParams(window.location.search);
    const q = params.get('q');
    if (q) {
      setTimeout(() => {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }, 300);
    }
  });
</script>
